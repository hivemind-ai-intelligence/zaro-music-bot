# ====================================
# 👵 ZARO MUSIC BOT - Configuration
# =====================================

# Discord Bot Token (REQUIRED
TOKEN=YOUR_BOT_TOKEN_HERE

# Discord Application/Client ID 
CLIENT_ID=YOUR_CLIENT_ID_HERE

# Default Prefix for Message Commands
PREFIX=!

# Bot Owner IDs - comma separated for multiple
OWNER_IDS=YOUR_DISCORD_USER_ID

# Genius API Key for Lyrics (optional but recommended)
# Get it from: https://genius.com/api-clients
GENIUS_API_KEY=YOUR_GENIUS_API_KEY_HERE

# Bot Status Type: PLAYING | WATCHING | LISTENING | STREAMING | COMPETING
STATUS_TYPE=LISTENING

# Bot Status Text
STATUS_TEXT=/play | 🴵 Music Bot

# Bot Status Interval in seconds (for cycling statuses)
STATUS_INTERVAL=15

# Default Volume (1-100)
DEFAULT_VOLUME=80

# Maximum Volume (1-1000)
MAX_VOLUME=200

# Auto-Leave empty VC after X seconds (0 = disabled / 24/7 mode)
AUTO_LEAVE_TIMEOUT=120

# Enable 24/7 mode by default
DEFAULT_247=false

# Lyrics Default Language Preference
DEFAULT_LYRICS_LANG=auto

# Embed Color (Hex)
EMBED_COLOR=#8A2BE2

# Debug Mode
DEBUG=false
